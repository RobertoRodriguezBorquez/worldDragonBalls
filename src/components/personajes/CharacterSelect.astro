---
import type { CharacterFull } from "@lib/api";
import { parseKi, isUnknownKi } from "@lib/api";
import FavoriteButton from "./FavoriteButton.astro";

interface Props {
  characters: CharacterFull[];
}
const { characters } = Astro.props;

const maxPower = Math.max(
  ...characters.map((c) => parseKi(c.maxKi) || parseKi(c.ki)),
  1
);
---

<section id="character-select" class="mx-auto max-w-7xl px-4 py-6">
  <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
    <div class="section-banner">
      <span aria-hidden="true">⚔</span>
      <span>Select Your Fighter</span>
    </div>
    <a
      href="/personajes"
      class="text-sm font-bold uppercase tracking-wider text-[var(--color-ki-orange)] hover:underline"
    >
      Ver roster completo →
    </a>
  </div>

  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 md:gap-4">
    {
      characters.map((c, i) => {
        const power = parseKi(c.maxKi) || parseKi(c.ki) || 0;
        const powerPct = Math.max(8, Math.round((power / maxPower) * 100));
        const slotNum = String(i + 1).padStart(2, "0");
        return (
          <article
            class="slot-frame group relative flex flex-col overflow-hidden"
            data-id={c.id}
            data-name={c.name.toLowerCase()}
          >
            <div class="flex items-center justify-between border-b-2 border-[var(--color-ink)] bg-gradient-to-r from-[var(--color-ki-orange)] to-[var(--color-ki-yellow)] px-2 py-1 text-[var(--color-ink)]">
              <span class="font-display text-xs tracking-widest">F{slotNum}</span>
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" aria-hidden="true">
                <polygon
                  points="12,2 14.6,8.6 21.6,9.2 16.2,13.8 17.8,20.4 12,16.8 6.2,20.4 7.8,13.8 2.4,9.2 9.4,8.6"
                  fill="var(--color-ink)"
                />
              </svg>
            </div>

            <a
              href={`/personajes/${c.id}`}
              class="relative block aspect-square overflow-hidden bg-[var(--color-bg-muted)]"
              aria-label={`Ver perfil de ${c.name}`}
            >
              <img
                src={c.image}
                alt={c.name}
                loading="lazy"
                referrerpolicy="no-referrer"
                class="h-full w-full object-contain p-2 transition duration-300 group-hover:scale-110"
              />
              <div
                class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                style="background: radial-gradient(circle at center, rgba(255,193,7,0.35) 0%, transparent 60%);"
                aria-hidden="true"
              />
              <span class="absolute left-1.5 bottom-1.5 rounded bg-[var(--color-ink)] px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[var(--color-ki-yellow)]">
                {c.race}
              </span>
            </a>

            <div class="flex flex-1 flex-col gap-1 p-2.5">
              <a href={`/personajes/${c.id}`} class="block">
                <h3 class="line-clamp-1 font-display text-sm uppercase tracking-wide text-[var(--color-text)] md:text-base">
                  {c.name}
                </h3>
              </a>
              <p class="line-clamp-1 text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-muted)]">
                {c.affiliation}
              </p>

              <div class="mt-1">
                <div class="mb-0.5 flex items-center justify-between text-[9px] font-bold uppercase tracking-wider text-[var(--color-text-muted)]">
                  <span>Power</span>
                  <span class="text-[var(--color-ki-orange)]">
                    {isUnknownKi(c.maxKi) && isUnknownKi(c.ki) ? "?" : c.maxKi !== "unknown" ? c.maxKi : c.ki}
                  </span>
                </div>
                <div class="hp-bar">
                  <div class="hp-bar-fill" style={`width: ${powerPct}%`}></div>
                </div>
              </div>

              <div class="mt-auto flex items-center justify-between gap-1 pt-1.5">
                <a
                  href={`/personajes/${c.id}`}
                  class="flex-1 rounded border-2 border-[var(--color-ink)] bg-[var(--color-ki-orange)] py-1 text-center font-display text-[10px] uppercase tracking-wider text-white transition hover:bg-[var(--color-ki-orange-hover)]"
                  style="box-shadow: 2px 2px 0 var(--color-ink);"
                >
                  Select
                </a>
                <FavoriteButton id={c.id} name={c.name} compact />
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>
