---
import type { CharacterFull } from "@lib/api";
import { getCharacterAura } from "@lib/api";

interface Props {
  characters: CharacterFull[];
  count?: number;
}
const { characters, count = 14 } = Astro.props;

const initial = characters[0];
const initialAura = initial ? getCharacterAura(initial) : "#ff5722";
---

<section id="character-select" class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
    <div class="section-banner">
      <span aria-hidden="true">⚔</span>
      <span>Select Your Fighter</span>
    </div>
    <a
      href="/personajes"
      class="text-sm font-bold uppercase tracking-wider text-[var(--color-ki-orange)] hover:underline"
    >
      Ver roster completo →
    </a>
  </div>

  <div
    id="mk-roster"
    class="mk-roster"
    style={`--aura: ${initialAura};`}
    data-count={count}
  >
    <div class="mk-stage">
      <div class="mk-stage-bg" aria-hidden="true"></div>
      <div class="mk-stage-platform" aria-hidden="true"></div>
      <div class="mk-stage-glow" aria-hidden="true"></div>
      <div class="mk-stage-corner mk-corner-tl" aria-hidden="true"></div>
      <div class="mk-stage-corner mk-corner-tr" aria-hidden="true"></div>
      <div class="mk-stage-corner mk-corner-bl" aria-hidden="true"></div>
      <div class="mk-stage-corner mk-corner-br" aria-hidden="true"></div>

      <div class="mk-stage-card">
        <img
          id="mk-stage-img"
          src={initial?.image}
          alt={initial?.name}
          loading="eager"
          decoding="async"
          referrerpolicy="no-referrer"
          width="280"
          height="320"
        />
      </div>
    </div>

    <div class="mk-name-block">
      <span class="mk-name-label">Select</span>
      <h2 id="mk-name" class="mk-name">{initial?.name}</h2>
    </div>

    <div class="mk-rombo" id="mk-rombo-grid">
      {
        characters.map((c, idx) => {
          const aura = getCharacterAura(c);
          const hidden = idx >= count;
          return (
            <button
              type="button"
              class="mk-tile"
              data-id={c.id}
              data-name={c.name}
              data-image={c.image}
              data-aura={aura}
              data-hidden={hidden ? "true" : undefined}
              style={`--aura: ${aura};`}
              aria-label={`Seleccionar ${c.name}`}
            >
              <span class="mk-tile-shape">
                <img
                  data-src={c.image}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              </span>
            </button>
          );
        })
      }
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.getElementById("mk-roster");
    if (!root) return;
    const N = parseInt(root.dataset.count || "14", 10);
    const stageImg = document.getElementById("mk-stage-img");
    const nameEl = document.getElementById("mk-name");
    const allTiles = Array.from(root.querySelectorAll(".mk-tile"));
    if (allTiles.length === 0) return;

    const shuffle = () => {
      const data = allTiles.map((t) => ({
        id: t.dataset.id,
        name: t.dataset.name,
        image: t.dataset.image,
        aura: t.dataset.aura,
      }));
      for (let i = data.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [data[i], data[j]] = [data[j], data[i]];
      }
      const chosen = data.slice(0, N);
      for (let i = 0; i < N; i++) {
        const t = allTiles[i];
        const c = chosen[i];
        if (!t || !c) continue;
        t.dataset.id = c.id;
        t.dataset.name = c.name;
        t.dataset.image = c.image;
        t.dataset.aura = c.aura;
        t.style.setProperty("--aura", c.aura);
        t.setAttribute("aria-label", "Seleccionar " + c.name);
        t.removeAttribute("data-hidden");
        const img = t.querySelector("img");
        if (img) {
          if (img.getAttribute("data-src") !== c.image) {
            img.setAttribute("data-src", c.image);
          }
          if (img.src !== c.image) img.src = c.image;
        }
      }
      for (let i = N; i < allTiles.length; i++) {
        allTiles[i].setAttribute("data-hidden", "true");
      }
      if (stageImg) {
        stageImg.src = chosen[0].image;
        stageImg.alt = chosen[0].name;
      }
      if (nameEl) nameEl.textContent = chosen[0].name;
      root.style.setProperty("--aura", chosen[0].aura);
      allTiles.forEach((t) => t.setAttribute("data-active", "false"));
      allTiles[0].setAttribute("data-active", "true");
    };

    shuffle();

    const update = (tile) => {
      if (!tile || tile.hasAttribute("data-hidden")) return;
      const data = {
        id: tile.dataset.id,
        name: tile.dataset.name,
        image: tile.dataset.image,
        aura: tile.dataset.aura,
      };
      if (stageImg) {
        stageImg.classList.add("fading");
        setTimeout(() => {
          stageImg.src = data.image;
          stageImg.alt = data.name;
          stageImg.classList.remove("fading");
        }, 140);
      }
      if (nameEl) nameEl.textContent = data.name;
      root.style.setProperty("--aura", data.aura);
      allTiles.forEach((t) => t.setAttribute("data-active", "false"));
      tile.setAttribute("data-active", "true");
    };

    allTiles.forEach((tile) => {
      tile.addEventListener("click", () => update(tile));
      tile.addEventListener("mouseenter", () => update(tile));
      tile.addEventListener("focus", () => update(tile));
      tile.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          update(tile);
        }
      });
    });
  })();
</script>
