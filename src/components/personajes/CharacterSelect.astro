---
import type { CharacterFull } from "@lib/api";
import CharacterHexGrid from "./CharacterHexGrid.astro";

interface Props {
  characters: CharacterFull[];
}
const { characters } = Astro.props;
---

<section id="character-select" class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
    <div class="section-banner">
      <span aria-hidden="true">⚔</span>
      <span>Random Roster</span>
    </div>
    <a
      href="/personajes"
      class="text-sm font-bold uppercase tracking-wider text-[var(--color-ki-orange)] hover:underline"
    >
      Ver roster completo →
    </a>
  </div>

  <CharacterHexGrid
    characters={characters}
    id="hex-grid-home"
    randomLimit={8}
    showcase={true}
  />
</section>
