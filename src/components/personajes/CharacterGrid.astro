---
import type { CharacterFull } from "@lib/api";
import CharacterCard from "./CharacterCard.astro";

interface Props {
  characters: CharacterFull[];
}
const { characters } = Astro.props;
---

<section
  id="character-grid"
  class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5"
>
  {characters.map((c) => <CharacterCard character={c} />)}
</section>

<div id="empty-state" class="hidden py-12 text-center text-[var(--color-text-muted)]">
  No se encontraron personajes con esos filtros.
</div>
