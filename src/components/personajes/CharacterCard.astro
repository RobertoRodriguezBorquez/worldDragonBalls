---
import type { CharacterFull } from "@lib/api";
import FavoriteButton from "./FavoriteButton.astro";

interface Props {
  character: CharacterFull;
}
const { character } = Astro.props;
---

<article
  class="character-card group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-md transition hover:-translate-y-1 hover:shadow-[var(--color-shadow)] animate-fade-up"
  data-name={character.name.toLowerCase()}
  data-race={character.race.toLowerCase()}
  data-affiliation={character.affiliation.toLowerCase()}
>
  <a href={`/personajes/${character.id}`} class="block">
    <div class="relative aspect-square overflow-hidden bg-gradient-to-br from-[var(--color-ki-yellow-soft)] to-[var(--color-bg-muted)]">
      <img
        src={character.image}
        alt={character.name}
        loading="lazy"
        referrerpolicy="no-referrer"
        class="h-full w-full object-contain p-2 transition duration-500 group-hover:scale-110"
      />
      <span class="absolute left-2 top-2 rounded-full bg-[var(--color-ki-orange)] px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white">
        {character.race}
      </span>
    </div>
  </a>

  <div class="flex flex-1 flex-col gap-2 p-3">
    <div class="flex items-start justify-between gap-2">
      <a href={`/personajes/${character.id}`} class="flex-1">
        <h3 class="line-clamp-1 text-base font-bold text-[var(--color-text)]">
          {character.name}
        </h3>
      </a>
      <FavoriteButton id={character.id} name={character.name} compact />
    </div>

    <p class="line-clamp-2 text-xs text-[var(--color-text-muted)]">
      {character.affiliation}
    </p>

    <div class="mt-auto flex items-center justify-between text-xs">
      <span class="font-semibold text-[var(--color-ki-orange)]">
        Ki: {character.ki}
      </span>
      <a
        href={`/personajes/${character.id}`}
        class="rounded-full bg-[var(--color-accent)] px-2.5 py-1 font-semibold text-white transition hover:bg-[var(--color-accent-hover)]"
      >
        Ver
      </a>
    </div>
  </div>
</article>
