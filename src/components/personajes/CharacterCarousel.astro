---
import type { CharacterFull } from "@lib/api";
import FavoriteButton from "./FavoriteButton.astro";

interface Props {
  characters: CharacterFull[];
}
const { characters } = Astro.props;
---

<section
  id="character-carousel"
  class="relative"
  data-count={characters.length}
>
  <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-8 bg-gradient-to-r from-[var(--color-bg)] to-transparent" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8 bg-gradient-to-l from-[var(--color-bg)] to-transparent" aria-hidden="true"></div>

  <button
    type="button"
    id="carousel-prev"
    class="absolute left-2 top-1/2 z-20 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full border-2 border-[var(--color-ink)] bg-[var(--color-surface)] text-[var(--color-ink)] shadow-md transition hover:scale-110 hover:bg-[var(--color-ki-orange)] hover:text-white disabled:opacity-30 disabled:hover:scale-100"
    style="box-shadow: 2px 2px 0 var(--color-ink);"
    aria-label="Anterior"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>

  <button
    type="button"
    id="carousel-next"
    class="absolute right-2 top-1/2 z-20 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full border-2 border-[var(--color-ink)] bg-[var(--color-surface)] text-[var(--color-ink)] shadow-md transition hover:scale-110 hover:bg-[var(--color-ki-orange)] hover:text-white disabled:opacity-30 disabled:hover:scale-100"
    style="box-shadow: 2px 2px 0 var(--color-ink);"
    aria-label="Siguiente"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </button>

  <ul
    id="carousel-track"
    class="scroll-snap-x no-scrollbar flex gap-4 overflow-x-auto px-12 py-2"
    tabindex="0"
    role="list"
  >
    {characters.map((c) => (
      <li
        class="carousel-item w-56 shrink-0 list-none sm:w-60"
        data-id={c.id}
        data-name={c.name.toLowerCase()}
      >
        <article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <a href={`/personajes/${c.id}`} class="block">
            <div class="relative aspect-square overflow-hidden bg-[var(--color-bg-muted)]">
              <img
                src={c.image}
                alt={c.name}
                loading="lazy"
                referrerpolicy="no-referrer"
                class="h-full w-full object-contain p-2 transition duration-300 group-hover:scale-105"
              />
              <span class="absolute left-2 top-2 rounded-full bg-[var(--color-ki-orange)] px-2 py-0.5 text-[10px] font-bold uppercase text-white">
                {c.race}
              </span>
              <span class="absolute right-2 top-2 rounded-md bg-[var(--color-ink)] px-1.5 py-0.5 text-[10px] font-bold text-[var(--color-ki-yellow)]">
                #{String(c.id).padStart(3, "0")}
              </span>
            </div>
          </a>
          <div class="flex flex-1 flex-col gap-1 p-3">
            <div class="flex items-start justify-between gap-2">
              <a href={`/personajes/${c.id}`} class="flex-1">
                <h3 class="line-clamp-1 text-sm font-bold text-[var(--color-text)]">
                  {c.name}
                </h3>
              </a>
              <FavoriteButton id={c.id} name={c.name} compact />
            </div>
            <p class="line-clamp-1 text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-muted)]">
              {c.affiliation}
            </p>
            <div class="mt-auto flex items-center justify-between pt-1">
              <span class="text-xs font-bold text-[var(--color-accent)]">
                {c.ki}
              </span>
              <a
                href={`/personajes/${c.id}`}
                class="rounded-full bg-[var(--color-accent)] px-2.5 py-1 text-[10px] font-semibold text-white transition hover:bg-[var(--color-accent-hover)]"
              >
                Ver
              </a>
            </div>
          </div>
        </article>
      </li>
    ))}
  </ul>

  <div
    id="carousel-dots"
    class="mt-4 flex items-center justify-center gap-1.5"
    aria-hidden="true"
  >
    {characters.map((_, i) => (
      <button
        type="button"
        class:list={[
          "carousel-dot h-1.5 rounded-full transition-all",
          i === 0 ? "w-6 bg-[var(--color-ki-orange)]" : "w-1.5 bg-[var(--color-border-strong)]",
        ]}
        data-index={i}
        aria-label={`Ir al personaje ${i + 1}`}
      />
    ))}
  </div>
</section>

<script is:inline>
  (() => {
    const carousel = document.getElementById("character-carousel");
    const track = document.getElementById("carousel-track");
    const prev = document.getElementById("carousel-prev");
    const next = document.getElementById("carousel-next");
    const dots = document.querySelectorAll(".carousel-dot");
    if (!carousel || !track || !prev || !next) return;

    const items = Array.from(track.querySelectorAll(".carousel-item"));
    const getStep = () => {
      const first = items[0];
      if (!first) return 280;
      const rect = first.getBoundingClientRect();
      const gap = parseInt(getComputedStyle(track).columnGap || "16", 10);
      return rect.width + gap;
    };

    const activeIndex = () => {
      const step = getStep();
      return Math.round(track.scrollLeft / step);
    };

    const updateDots = () => {
      const idx = activeIndex();
      dots.forEach((dot, i) => {
        if (i === idx) {
          dot.classList.add("w-6", "bg-[var(--color-ki-orange)]");
          dot.classList.remove("w-1.5", "bg-[var(--color-border-strong)]");
        } else {
          dot.classList.remove("w-6", "bg-[var(--color-ki-orange)]");
          dot.classList.add("w-1.5", "bg-[var(--color-border-strong)]");
        }
      });
      const max = track.scrollWidth - track.clientWidth - 2;
      prev.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= max;
    };

    prev.addEventListener("click", () => {
      track.scrollBy({ left: -getStep(), behavior: "smooth" });
    });
    next.addEventListener("click", () => {
      track.scrollBy({ left: getStep(), behavior: "smooth" });
    });
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const i = Number(dot.dataset.index || 0);
        track.scrollTo({ left: i * getStep(), behavior: "smooth" });
      });
    });
    track.addEventListener("scroll", updateDots, { passive: true });
    window.addEventListener("resize", updateDots);
    updateDots();

    let autoTimer = null;
    const startAuto = () => {
      stopAuto();
      autoTimer = setInterval(() => {
        const max = track.scrollWidth - track.clientWidth - 2;
        if (track.scrollLeft >= max) {
          track.scrollTo({ left: 0, behavior: "smooth" });
        } else {
          track.scrollBy({ left: getStep(), behavior: "smooth" });
        }
      }, 5000);
    };
    const stopAuto = () => {
      if (autoTimer) clearInterval(autoTimer);
      autoTimer = null;
    };
    startAuto();
    carousel.addEventListener("mouseenter", stopAuto);
    carousel.addEventListener("mouseleave", startAuto);
    carousel.addEventListener("focusin", stopAuto);
    carousel.addEventListener("focusout", startAuto);
  })();
</script>
