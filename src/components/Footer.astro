---
const year = new Date().getFullYear();
---

<footer class="mt-12 border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-4 py-8 text-center text-sm text-[var(--color-text-muted)]">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-3">
    <img src="/svg/dragonball-z.svg" alt="Dragon Ball Z" class="h-10 w-auto opacity-80" />
    <p>
      © {year} <strong class="text-[var(--color-text)]">World Dragon Balls</strong> — Fan project, no afiliado oficialmente.
    </p>
    <p class="text-xs opacity-70">
      Datos provistos por
      <a
        href="https://dragonball-api.com"
        target="_blank"
        rel="noopener noreferrer"
        class="underline hover:text-[var(--color-accent)]"
      >
        dragonball-api.com
      </a>
    </p>
  </div>
</footer>
