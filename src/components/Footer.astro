---
import { getLocaleFromUrl, getDictionary } from "@lib/i18n";

const locale = getLocaleFromUrl(Astro.url);
const dict = getDictionary(locale);
const year = new Date().getFullYear();
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/", label: dict.nav.home, match: (p: string) => p === "/" || p === "/en" || p === "/en/" },
  { href: "/personajes", label: dict.nav.characters, match: (p: string) => p.startsWith("/personajes") },
  { href: "/favoritos", label: dict.nav.favorites, match: (p: string) => p.startsWith("/favoritos") },
  { href: "/comparador", label: dict.nav.compare, match: (p: string) => p.startsWith("/comparador") },
] as const;
---

<footer class="relative mt-12 border-t-[3px] border-[var(--color-ink)] bg-[var(--color-bg-elevated)]">
  <div
    aria-hidden="true"
    class="h-1 w-full bg-[repeating-linear-gradient(45deg,var(--color-ki-orange)_0_10px,var(--color-ki-yellow)_10px_20px,var(--color-ki-red)_20px_30px)]"
  ></div>

  <div
    class="mx-auto flex max-w-7xl flex-col items-center gap-5 px-4 py-6 sm:flex-row sm:justify-between sm:gap-6"
  >
    <a
      href="/"
      class="flex items-center gap-2 text-sm font-semibold text-[var(--color-text)] transition hover:text-[var(--color-ki-orange)]"
      aria-label={dict.nav.home}
    >
      <img src="/svg/dragonball-z.svg" alt="" class="h-7 w-auto" loading="lazy" aria-hidden="true" />
      <span class="font-[var(--font-display)] uppercase tracking-wider">
        World <span class="text-[var(--color-ki-red)]">DB</span>
      </span>
    </a>

    <nav aria-label="Footer" class="flex flex-wrap items-center justify-center gap-1.5">
      {
        navItems.map((item) => {
          const active = item.match(pathname);
          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "rounded-full border-[2px] border-[var(--color-ink)] px-3 py-1 text-xs font-semibold transition-all duration-150",
                "active:translate-x-[1px] active:translate-y-[1px]",
                active
                  ? "bg-[var(--color-ki-orange)] text-[var(--color-ink)] shadow-none"
                  : "bg-[var(--color-surface)] text-[var(--color-text)] shadow-[2px_2px_0_var(--color-ink)] hover:-translate-y-0.5 hover:bg-[var(--color-ki-yellow)]",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex flex-col items-center gap-0.5 text-xs text-[var(--color-text-muted)] sm:items-end">
      <p>
        © {year} <strong class="text-[var(--color-text)]">World Dragon Balls</strong>
      </p>
      <p>
        {locale === "en" ? "Data:" : "Datos:"}
        <a
          href="https://dragonball-api.com"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 font-semibold text-[var(--color-text)] underline decoration-[var(--color-ki-orange)] decoration-2 underline-offset-2 hover:text-[var(--color-ki-orange)]"
        >
          dragonball-api.com
        </a>
      </p>
    </div>
  </div>
</footer>
