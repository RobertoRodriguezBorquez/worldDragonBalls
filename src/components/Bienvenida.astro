---
import { getLocaleFromUrl, getDictionary } from "@lib/i18n";

const locale = getLocaleFromUrl(Astro.url);
const dict = getDictionary(locale);
const year = new Date().getFullYear();

interface Props {
  characterCount?: number;
  sagaCount?: number;
  raceCount?: number;
}
const {
  characterCount = 0,
  sagaCount = 0,
  raceCount = 0,
} = Astro.props;
---

<section
  id="welcome"
  class="relative mx-auto max-w-7xl px-4 pb-8 pt-10 md:pb-12 md:pt-16"
>
  <div class="relative flex flex-col items-center text-center">
    <div
      class="mb-5 flex items-center justify-center gap-2.5 md:mb-6 md:gap-3"
      role="img"
      aria-label="Esferas del dragón"
    >
      {
        [1, 2, 3, 4].map((n) => (
          <svg
            viewBox="0 0 24 24"
            class="db-ball h-11 w-11 md:h-14 md:w-14"
            aria-hidden="true"
          >
            <defs>
              <radialGradient id={`db-shine-${n}`} cx="0.35" cy="0.3" r="0.7">
                <stop offset="0%" stop-color="#fff3cd" stop-opacity="0.85" />
                <stop offset="60%" stop-color="var(--color-ki-orange, #ff5722)" stop-opacity="0" />
              </radialGradient>
            </defs>
            <circle cx="12" cy="12" r="10.5" fill={`url(#db-shine-${n})`} />
            <circle cx="12" cy="12" r="10.5" fill="var(--color-ki-orange, #ff5722)" />
            <circle cx="12" cy="12" r="10.5" fill="none" stroke="var(--color-ki-red, #e53935)" stroke-width="1.1" />
            <g fill="var(--color-ki-red, #e53935)" class="db-stars">
              {n >= 1 && (
                <polygon
                  class="db-star"
                  style="animation-delay:0s"
                  points="12,8.5 12.6,9.75 14,8.85 12.95,9.75 13.3,11.05 12,10.35 10.7,11.05 11.05,9.75 10,8.85 11.4,9.75"
                />
              )}
              {n >= 2 && (
                <polygon
                  class="db-star"
                  style="animation-delay:0.18s"
                  points="12,8.5 12.6,9.75 14,8.85 12.95,9.75 13.3,11.05 12,10.35 10.7,11.05 11.05,9.75 10,8.85 11.4,9.75"
                  transform="translate(0,5)"
                />
              )}
              {n >= 3 && (
                <polygon
                  class="db-star"
                  style="animation-delay:0.36s"
                  points="12,8.5 12.6,9.75 14,8.85 12.95,9.75 13.3,11.05 12,10.35 10.7,11.05 11.05,9.75 10,8.85 11.4,9.75"
                  transform="translate(3.2,2.5)"
                />
              )}
              {n >= 4 && (
                <polygon
                  class="db-star"
                  style="animation-delay:0.54s"
                  points="12,8.5 12.6,9.75 14,8.85 12.95,9.75 13.3,11.05 12,10.35 10.7,11.05 11.05,9.75 10,8.85 11.4,9.75"
                  transform="translate(-3.2,2.5)"
                />
              )}
            </g>
          </svg>
        ))
      }
    </div>

    <span
      class="mb-4 inline-flex items-center gap-2 rounded-full border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-3 py-1 font-[var(--font-display)] text-[10px] uppercase tracking-[0.2em] text-[var(--color-text)] shadow-[2px_2px_0_var(--color-ink)] md:mb-5"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-ki-red)]" aria-hidden="true"></span>
      {dict.home.welcome.kicker}
    </span>

    <h1
      class="font-[var(--font-display)] text-4xl uppercase leading-[0.95] tracking-tight text-[var(--color-text)] md:text-6xl lg:text-7xl"
    >
      {dict.home.welcome.title}
    </h1>

    <div class="my-4 flex w-full max-w-md items-center gap-3 md:my-5">
      <span class="h-[2px] flex-1 bg-[var(--color-ink)]"></span>
      <span
        class="font-[var(--font-display)] text-[11px] uppercase tracking-[0.25em] text-[var(--color-text-muted)] md:text-xs"
      >
        {dict.home.welcome.subtitle}
      </span>
      <span class="h-[2px] flex-1 bg-[var(--color-ink)]"></span>
    </div>

    <p class="max-w-2xl text-sm text-[var(--color-text-muted)] md:text-base">
      {dict.home.welcome.description}
    </p>

    {
      (characterCount > 0 || sagaCount > 0 || raceCount > 0) && (
        <div class="mt-6 flex flex-wrap items-stretch justify-center gap-2 md:mt-7 md:gap-3">
          {characterCount > 0 && (
            <div class="rounded-xl border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-4 py-2 shadow-[2px_2px_0_var(--color-ink)]">
              <span class="block font-[var(--font-display)] text-2xl text-[var(--color-text)] md:text-3xl">
                {characterCount}+
              </span>
              <span class="block font-[var(--font-display)] text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
                {dict.home.welcome.statCharacters}
              </span>
            </div>
          )}
          {sagaCount > 0 && (
            <div class="rounded-xl border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-4 py-2 shadow-[2px_2px_0_var(--color-ink)]">
              <span class="block font-[var(--font-display)] text-2xl text-[var(--color-text)] md:text-3xl">
                {sagaCount}
              </span>
              <span class="block font-[var(--font-display)] text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
                {dict.home.welcome.statSagas}
              </span>
            </div>
          )}
          {raceCount > 0 && (
            <div class="rounded-xl border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-4 py-2 shadow-[2px_2px_0_var(--color-ink)]">
              <span class="block font-[var(--font-display)] text-2xl text-[var(--color-text)] md:text-3xl">
                {raceCount}+
              </span>
              <span class="block font-[var(--font-display)] text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
                {dict.home.welcome.statRaces}
              </span>
            </div>
          )}
        </div>
      )
    }

    <div class="mt-6 flex flex-col items-center gap-3 md:mt-8 md:flex-row md:gap-4">
      <a
        href="/personajes"
        class="inline-flex items-center gap-2 rounded-full border-[2.5px] border-[var(--color-ink)] bg-[var(--color-ki-orange)] px-5 py-2.5 text-sm font-semibold text-[var(--color-ink)] shadow-[3px_3px_0_var(--color-ink)] transition-all duration-150 hover:-translate-y-0.5 hover:bg-[var(--color-ki-yellow)] hover:shadow-[4px_4px_0_var(--color-ink)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v14H6a2 2 0 0 0-2 2V5Z" />
          <path d="M8 7h7M8 11h7" />
        </svg>
        {dict.home.welcome.ctaBrowse}
      </a>
      <a
        href="/comparador"
        class="inline-flex items-center gap-2 rounded-full border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] shadow-[3px_3px_0_var(--color-ink)] transition-all duration-150 hover:-translate-y-0.5 hover:bg-[var(--color-ki-blue)] hover:text-white hover:shadow-[4px_4px_0_var(--color-ink)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="13,2 4,14 11,14 9,22 20,9 13,9" />
        </svg>
        {dict.home.welcome.ctaCompare}
      </a>
    </div>

    <p
      class="mt-6 font-[var(--font-display)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-text-muted)] md:mt-8"
    >
      © {year} World Dragon Balls — {dict.home.welcome.tagline}
    </p>
  </div>
</section>

<style>
  @keyframes db-twinkle {
    0%, 100% {
      opacity: 0.35;
      transform: scale(0.88);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }
  .db-star {
    transform-box: fill-box;
    transform-origin: center;
    animation: db-twinkle 1.8s ease-in-out infinite;
    filter: drop-shadow(0 0 1.5px var(--color-ki-red, #e53935));
  }
  .db-ball {
    transition: transform 0.3s ease;
  }
  .db-ball:hover {
    transform: translateY(-2px) rotate(-4deg);
  }
  .db-ball:hover .db-star {
    animation-duration: 0.9s;
  }
</style>
