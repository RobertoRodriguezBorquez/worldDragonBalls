---
import { getLocaleFromUrl, getDictionary } from "@lib/i18n";

const locale = getLocaleFromUrl(Astro.url);
const dict = getDictionary(locale);
const year = new Date().getFullYear();

interface Props {
  characterCount?: number;
  sagaCount?: number;
  raceCount?: number;
}
const {
  characterCount = 0,
  sagaCount = 0,
  raceCount = 0,
} = Astro.props;

const starPoly = "12,10.8 12.294,11.596 13.141,11.629 12.476,12.155 12.706,12.971 12,12.5 11.294,12.971 11.524,12.155 10.859,11.629 11.706,11.596";

const starPositions = [
  [[0, 0]],
  [[0, -2.4], [0, 2.4]],
  [[0, -2.5], [2.2, 1.3], [-2.2, 1.3]],
  [[0, -2.9], [-2.5, -0.3], [2.5, -0.3], [0, 2.3]],
  [[0, -3.1], [3.0, -1.0], [1.8, 2.5], [-1.8, 2.5], [-3.0, -1.0]],
  [[0, -3.7], [3.2, -1.9], [3.2, 1.9], [0, 3.7], [-3.2, 1.9], [-3.2, -1.9]],
];

let _starIdx = 0;
const dragonBalls = [1, 2, 3, 4, 5, 6].map((n) => ({
  n,
  stars: starPositions[n - 1].map(([ox, oy]) => {
    const delay = (_starIdx * 0.1).toFixed(2) + "s";
    _starIdx++;
    return { ox, oy, delay };
  }),
}));

const scatterBalls = [
  { cls: "left-[5%] top-[5%] md:left-[8%] md:top-[7%]", rot: -8 },
  { cls: "right-[5%] top-[3%] md:right-[8%] md:top-[5%]", rot: 6 },
  { cls: "left-[1%] top-[45%] hidden lg:block", rot: -5 },
  { cls: "right-[2%] top-[40%] hidden lg:block", rot: 5 },
  { cls: "left-[6%] bottom-[6%] md:left-[10%] md:bottom-[12%]", rot: -7 },
  { cls: "right-[6%] bottom-[4%] md:right-[10%] md:bottom-[10%]", rot: 7 },
];
---

<section
  id="welcome"
  class="relative mx-auto max-w-7xl overflow-hidden px-4 pb-10 pt-10 md:pb-14 md:pt-16"
>
  <!-- Welcome aura: centered glow -->
  <div
    class="welcome-aura pointer-events-none absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 md:h-96 md:w-96"
    aria-hidden="true"
  >
    <div class="welcome-aura-glow"></div>
  </div>

  <!-- Scattered dragon balls -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    {
      dragonBalls.map(({ n, stars }, i) => (
        <div
          class={`absolute ${scatterBalls[i].cls} scatter-ball`}
          style={`--rot: ${scatterBalls[i].rot}deg`}
        >
          <svg
            viewBox="0 0 24 24"
            class="h-9 w-9 md:h-11 md:w-11"
            aria-hidden="true"
          >
            <defs>
              <radialGradient id={`ball-sct-${n}`} cx="0.4" cy="0.32" r="0.72">
                <stop offset="0%" stop-color="#ffba8a" />
                <stop offset="35%" stop-color="#f06820" />
                <stop offset="80%" stop-color="#c04010" />
                <stop offset="100%" stop-color="#7a1a08" />
              </radialGradient>
            </defs>
            <circle cx="12" cy="12" r="10.5" fill={`url(#ball-sct-${n})`} />
            <circle cx="12" cy="12" r="10.5" fill="none" stroke="#5a1004" stroke-width="0.5" />
            <g fill="#8b1a08" stroke="#3a0804" stroke-width="0.25" stroke-linejoin="round">
              {stars.map(({ ox, oy, delay }) => (
                <g transform={`translate(${ox} ${oy})`}>
                  <polygon
                    class="db-star"
                    points={starPoly}
                    style={`animation-delay:${delay}`}
                  />
                </g>
              ))}
            </g>
            <ellipse cx="9.2" cy="6.8" rx="2.3" ry="1.1" fill="#ffffff" opacity="0.8" transform="rotate(-35 9.2 6.8)" />
            <ellipse cx="14.5" cy="5.6" rx="0.9" ry="0.5" fill="#ffffff" opacity="0.9" />
            <ellipse cx="6.6" cy="10.4" rx="0.45" ry="0.9" fill="#ffffff" opacity="0.4" transform="rotate(-25 6.6 10.4)" />
          </svg>
        </div>
      ))
    }
  </div>

  <!-- Main content -->
  <div class="relative z-10 flex flex-col items-center text-center">
    <span
      class="mb-4 inline-flex items-center gap-2 rounded-full border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-3 py-1 font-[var(--font-display)] text-[10px] uppercase tracking-[0.2em] text-[var(--color-text)] shadow-[2px_2px_0_var(--color-ink)] md:mb-5"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-ki-red)]" aria-hidden="true"></span>
      {dict.home.welcome.kicker}
    </span>

    <h1
      class="welcome-title font-[var(--font-display)] text-4xl uppercase leading-[0.95] tracking-tight text-[var(--color-text)] md:text-6xl lg:text-7xl"
    >
      {dict.home.welcome.title}
    </h1>

    <div class="my-4 flex w-full max-w-md items-center gap-3 md:my-5">
      <span class="h-[2px] flex-1 bg-[var(--color-ink)]"></span>
      <span
        class="font-[var(--font-display)] text-[11px] uppercase tracking-[0.25em] text-[var(--color-text-muted)] md:text-xs"
      >
        {dict.home.welcome.subtitle}
      </span>
      <span class="h-[2px] flex-1 bg-[var(--color-ink)]"></span>
    </div>

    <p class="welcome-text max-w-2xl text-sm text-[var(--color-text-muted)] md:text-base">
      {dict.home.welcome.description}
    </p>

    {
      (characterCount > 0 || sagaCount > 0 || raceCount > 0) && (
        <div class="mt-6 flex flex-wrap items-stretch justify-center gap-2 md:mt-7 md:gap-3">
          {characterCount > 0 && (
            <div class="rounded-xl border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-4 py-2 shadow-[2px_2px_0_var(--color-ink)]">
              <span class="block font-[var(--font-display)] text-2xl text-[var(--color-text)] md:text-3xl">
                {characterCount}+
              </span>
              <span class="block font-[var(--font-display)] text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
                {dict.home.welcome.statCharacters}
              </span>
            </div>
          )}
          {sagaCount > 0 && (
            <div class="rounded-xl border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-4 py-2 shadow-[2px_2px_0_var(--color-ink)]">
              <span class="block font-[var(--font-display)] text-2xl text-[var(--color-text)] md:text-3xl">
                {sagaCount}
              </span>
              <span class="block font-[var(--font-display)] text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
                {dict.home.welcome.statSagas}
              </span>
            </div>
          )}
          {raceCount > 0 && (
            <div class="rounded-xl border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-4 py-2 shadow-[2px_2px_0_var(--color-ink)]">
              <span class="block font-[var(--font-display)] text-2xl text-[var(--color-text)] md:text-3xl">
                {raceCount}+
              </span>
              <span class="block font-[var(--font-display)] text-[9px] uppercase tracking-widest text-[var(--color-text-muted)]">
                {dict.home.welcome.statRaces}
              </span>
            </div>
          )}
        </div>
      )
    }

    <div class="mt-6 flex flex-col items-center gap-3 md:mt-8 md:flex-row md:gap-4">
      <a
        href="/personajes"
        class="inline-flex items-center gap-2 rounded-full border-[2.5px] border-[var(--color-ink)] bg-[var(--color-ki-orange)] px-5 py-2.5 text-sm font-semibold text-[var(--color-ink)] shadow-[3px_3px_0_var(--color-ink)] transition-all duration-150 hover:-translate-y-0.5 hover:bg-[var(--color-ki-yellow)] hover:shadow-[4px_4px_0_var(--color-ink)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v14H6a2 2 0 0 0-2 2V5Z" />
          <path d="M8 7h7M8 11h7" />
        </svg>
        {dict.home.welcome.ctaBrowse}
      </a>
      <a
        href="/comparador"
        class="inline-flex items-center gap-2 rounded-full border-[2.5px] border-[var(--color-ink)] bg-[var(--color-surface)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] shadow-[3px_3px_0_var(--color-ink)] transition-all duration-150 hover:-translate-y-0.5 hover:bg-[var(--color-ki-blue)] hover:text-white hover:shadow-[4px_4px_0_var(--color-ink)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="13,2 4,14 11,14 9,22 20,9 13,9" />
        </svg>
        {dict.home.welcome.ctaCompare}
      </a>
    </div>

    <p
      class="mt-6 font-[var(--font-display)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-text-muted)] md:mt-8"
    >
      &copy; {year} World Dragon Balls &mdash; {dict.home.welcome.tagline}
    </p>
  </div>
</section>

<style>
  @keyframes db-twinkle {
    0%, 100% {
      opacity: 0.7;
      transform: scale(0.92);
    }
    50% {
      opacity: 1;
      transform: scale(1.12);
    }
  }

  .db-star {
    transform-box: fill-box;
    transform-origin: center;
    animation: db-twinkle 1.8s ease-in-out infinite;
    filter: drop-shadow(0 0 0.4px rgba(255, 255, 255, 0.4))
      drop-shadow(0 0 1px rgba(255, 193, 7, 0.5));
  }

  .scatter-ball {
    transform: rotate(var(--rot));
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.12))
      drop-shadow(0 0 8px rgba(229, 57, 53, 0.18));
  }
  .scatter-ball:hover {
    transform: rotate(calc(var(--rot) - 2deg)) scale(1.08);
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.18))
      drop-shadow(0 0 14px rgba(229, 57, 53, 0.3));
  }
  .scatter-ball:hover .db-star {
    animation-duration: 0.9s;
  }

  /* Welcome aura glow */
  .welcome-aura-glow {
    position: absolute;
    inset: -25%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--color-ki-yellow) 0%,
      var(--color-ki-orange) 38%,
      transparent 70%
    );
    animation: ki-aura-pulse 3s ease-in-out infinite;
    filter: blur(22px);
    z-index: 0;
    pointer-events: none;
  }

  /* Text readability over the aura glow */
  .welcome-title {
    text-shadow:
      0 0 12px var(--color-bg-elevated),
      0 0 24px var(--color-bg-elevated),
      0 1px 3px var(--color-bg);
  }

  .welcome-text {
    text-shadow: 0 0 8px var(--color-bg);
  }
</style>
