---
const sagas = [
  { id: "saiyan", name: "Saiyan", color: "from-orange-500 to-amber-500" },
  { id: "frieza", name: "Namek / Frieza", color: "from-fuchsia-600 to-purple-700" },
  { id: "cell", name: "Cell", color: "from-emerald-500 to-green-700" },
  { id: "buu", name: "Buu", color: "from-pink-500 to-rose-700" },
  { id: "beerus", name: "Beerus", color: "from-indigo-500 to-purple-800" },
  { id: "tournament", name: "Tournament", color: "from-sky-500 to-cyan-700" },
  { id: "gt", name: "DB GT", color: "from-red-500 to-orange-700" },
  { id: "super-hero", name: "Super Hero", color: "from-yellow-400 to-amber-600" },
];
---

<section class="mx-auto max-w-7xl px-4 py-6 pb-12">
  <h2 class="mb-4 text-xl font-bold text-[var(--color-text)] md:text-2xl">
    Línea de tiempo
  </h2>
  <div
    class="scroll-snap-x -mx-4 flex gap-3 overflow-x-auto px-4 pb-2"
    aria-label="Sagas de Dragon Ball"
  >
    {
      sagas.map((s, i) => (
        <a
          href={`/personajes?saga=${s.id}`}
          class={`flex h-20 w-36 shrink-0 items-end rounded-xl bg-gradient-to-br ${s.color} p-3 text-sm font-bold text-white shadow-sm transition hover:scale-105 hover:shadow-md`}
          aria-label={`Saga ${s.name}`}
        >
          <span>
            <span class="block text-[10px] font-semibold uppercase tracking-wider opacity-80">
              Cap {String(i + 1).padStart(2, "0")}
            </span>
            {s.name}
          </span>
        </a>
      ))
    }
  </div>
</section>
