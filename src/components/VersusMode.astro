---
import type { CharacterFull } from "@lib/api";

interface Props {
  fighterA: CharacterFull;
  fighterB: CharacterFull;
}
const { fighterA, fighterB } = Astro.props;
const compareHref = `/comparador?a=${fighterA.id}&b=${fighterB.id}`;
---

<section id="versus-mode" class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-5 flex items-center justify-center">
    <div class="section-banner">
      <span aria-hidden="true">▶</span>
      <span>Versus Mode</span>
      <span aria-hidden="true">◀</span>
    </div>
  </div>

  <div
    class="relative overflow-hidden rounded-2xl border-[3px] border-[var(--color-ink)]"
    style="background: linear-gradient(135deg, var(--color-ki-orange) 0%, var(--color-ki-red) 50%, var(--color-ki-blue) 100%); box-shadow: 6px 6px 0 var(--color-ink);"
  >
    <div class="grid grid-cols-2">
      <a
        href={`/personajes/${fighterA.id}`}
        class="clip-vs-left relative flex flex-col items-center justify-center gap-2 bg-black/30 p-4 transition hover:bg-black/20 md:gap-3 md:p-8"
        aria-label={`Ver perfil de ${fighterA.name}`}
      >
        <div class="aspect-square w-32 md:w-48">
          <img
            src={fighterA.image}
            alt={fighterA.name}
            loading="lazy"
            referrerpolicy="no-referrer"
            class="h-full w-full object-contain drop-shadow-[0_0_15px_rgba(255,107,61,0.6)]"
          />
        </div>
        <div class="text-center text-white">
          <p class="font-display text-xl uppercase tracking-wider md:text-3xl">
            {fighterA.name}
          </p>
          <p class="mt-1 text-[10px] font-bold uppercase tracking-widest opacity-90 md:text-xs">
            {fighterA.race} · {fighterA.affiliation}
          </p>
          <p class="mt-1 font-mono text-xs font-bold text-[var(--color-ki-yellow)] md:text-sm">
            ⚡ {fighterA.maxKi}
          </p>
        </div>
      </a>

      <a
        href={`/personajes/${fighterB.id}`}
        class="clip-vs-right relative flex flex-col items-center justify-center gap-2 bg-black/30 p-4 transition hover:bg-black/20 md:gap-3 md:p-8"
        aria-label={`Ver perfil de ${fighterB.name}`}
      >
        <div class="aspect-square w-32 md:w-48">
          <img
            src={fighterB.image}
            alt={fighterB.name}
            loading="lazy"
            referrerpolicy="no-referrer"
            class="h-full w-full object-contain drop-shadow-[0_0_15px_rgba(74,158,255,0.6)]"
          />
        </div>
        <div class="text-center text-white">
          <p class="font-display text-xl uppercase tracking-wider md:text-3xl">
            {fighterB.name}
          </p>
          <p class="mt-1 text-[10px] font-bold uppercase tracking-widest opacity-90 md:text-xs">
            {fighterB.race} · {fighterB.affiliation}
          </p>
          <p class="mt-1 font-mono text-xs font-bold text-[var(--color-ki-yellow)] md:text-sm">
            ⚡ {fighterB.maxKi}
          </p>
        </div>
      </a>
    </div>

    <div class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2" aria-hidden="true">
      <div class="vs-circle relative grid h-20 w-20 place-items-center rounded-full border-[3px] border-[var(--color-ink)] bg-[var(--color-ki-yellow)] md:h-28 md:w-28" style="box-shadow: 4px 4px 0 var(--color-ink);">
        <svg viewBox="0 0 36 36" class="absolute inset-0 h-full w-full text-[var(--color-ink)] opacity-20">
          <circle cx="18" cy="18" r="16" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" />
        </svg>
        <span class="font-display-shade text-3xl text-[var(--color-ink)] md:text-5xl">VS</span>
      </div>
    </div>

    <div class="border-t-[3px] border-[var(--color-ink)] bg-black/60 p-4 md:p-6">
      <div class="flex flex-col items-center gap-3">
        <p class="font-display text-xs uppercase tracking-[0.3em] text-[var(--color-ki-yellow)] md:text-sm">
          Compare Two Fighters
        </p>
        <a
          href={compareHref}
          class="btn-arcade text-sm md:text-base"
          aria-label={`Iniciar batalla entre ${fighterA.name} y ${fighterB.name}`}
        >
          <span aria-hidden="true">⚔</span>
          Start Battle
        </a>
      </div>
    </div>
  </div>
</section>
