---
import { getLocaleFromUrl, getDictionary } from "@lib/i18n";

const locale = getLocaleFromUrl(Astro.url);
const dict = getDictionary(locale);
---
<section
  id="hero-video"
  class="fixed inset-0 z-30 flex h-screen w-screen items-center justify-center overflow-hidden bg-[var(--color-bg-muted)]"
>
  <div
    id="hero-loader"
    class="absolute inset-0 z-30 flex flex-col items-center justify-center bg-[var(--color-bg-muted)] transition-opacity duration-500"
    role="status"
    aria-live="polite"
  >
    <div class="db-spin" aria-hidden="true">
      <svg viewBox="0 0 64 64" class="h-20 w-20">
        <circle cx="32" cy="32" r="28" fill="var(--color-ki-yellow-soft)" stroke="var(--color-ki-orange)" stroke-width="3" />
        <g fill="var(--color-ki-red)">
          <polygon points="32,12 33.5,15.5 37,15.7 34.3,18 35.1,21.5 32,19.6 28.9,21.5 29.7,18 27,15.7 30.5,15.5" />
          <polygon points="22,30 22.9,32 25,32.1 23.5,33.4 24,35.5 22,34.4 20,35.5 20.5,33.4 19,32.1 21.1,32" />
          <polygon points="42,30 42.9,32 45,32.1 43.5,33.4 44,35.5 42,34.4 40,35.5 40.5,33.4 39,32.1 41.1,32" />
          <polygon points="32,40 32.9,42 35,42.1 33.5,43.4 34,45.5 32,44.4 30,45.5 30.5,43.4 29,42.1 31.1,42" />
        </g>
      </svg>
    </div>

    <p
      data-i18n="intro.loading"
      class="mt-5 font-[var(--font-display)] text-sm uppercase tracking-[0.25em] text-[var(--color-text)] md:text-base"
    >
      {dict.intro.loading}
    </p>

    <div class="mt-4 h-2 w-56 overflow-hidden rounded-full border-2 border-[var(--color-ink)] bg-[var(--color-ink)]/30">
      <div
        id="loader-progress"
        class="h-full rounded-full bg-gradient-to-r from-[var(--color-ki-orange)] to-[var(--color-ki-yellow)] transition-[width] duration-200"
        style="width: 0%; box-shadow: 0 0 8px var(--color-ki-orange);"
      ></div>
    </div>

    <p class="mt-2 font-mono text-xs text-[var(--color-text-muted)]">
      <span id="loader-time">0.0s</span>
      <span class="mx-1 opacity-50">·</span>
      <span id="loader-percent">0%</span>
    </p>

    <p
      data-i18n="intro.preparing"
      class="mt-3 font-mono text-[10px] uppercase tracking-[0.25em] text-[var(--color-text-muted)]"
    >
      {dict.intro.preparing}
    </p>
  </div>

  <video
    id="hero-video-el"
    class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"
    autoplay
    muted
    playsinline
    preload="auto"
    poster="/presentacion/nube-fondo.png"
    aria-label={dict.intro.loading}
  >
    <source src="/presentacion/video.mp4" type="video/mp4" />
  </video>

  <div
    id="hero-overlay"
    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-700"
    style="background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, transparent 30%, transparent 70%, var(--color-bg) 100%);"
    aria-hidden="true"
  ></div>

  <div
    id="hero-bottom-bar"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-10 flex items-end justify-between gap-3 px-4 pb-5 opacity-0 transition-opacity duration-500 sm:px-6 sm:pb-6"
  >
    <button
      type="button"
      id="hero-mute"
      class="btn-arcade-ghost pointer-events-auto !border-white/40 !text-white !shadow-[2px_2px_0_rgba(255,193,7,0.6)] hover:!bg-[var(--color-ki-yellow)] hover:!text-[var(--color-ink)]"
      style="font-size: 0.7rem; padding: 0.45rem 0.9rem;"
      aria-label={dict.intro.mute}
    >
      <span id="hero-mute-icon" aria-hidden="true">🔇</span>
      <span data-i18n="intro.mute" id="hero-mute-label">{dict.intro.mute}</span>
    </button>

    <div
      id="hero-progress"
      class="pointer-events-none flex items-center gap-2 rounded-full border-2 border-[var(--color-ki-yellow)] bg-black/60 px-2 py-1.5 text-white backdrop-blur"
      style="box-shadow: 2px 2px 0 rgba(255,193,7,0.6);"
      aria-label={dict.intro.time}
    >
      <div class="relative h-9 w-9">
        <svg viewBox="0 0 36 36" class="absolute inset-0 h-full w-full -rotate-90">
          <circle
            cx="18"
            cy="18"
            r="15"
            fill="none"
            stroke="rgba(255,193,7,0.2)"
            stroke-width="3"
          />
          <circle
            id="hero-progress-ring"
            cx="18"
            cy="18"
            r="15"
            fill="none"
            stroke="var(--color-ki-yellow)"
            stroke-width="3"
            stroke-linecap="round"
            stroke-dasharray="94.25"
            stroke-dashoffset="94.25"
            style="transition: stroke-dashoffset 0.3s linear; filter: drop-shadow(0 0 4px var(--color-ki-yellow));"
          />
        </svg>
        <div class="absolute inset-0 flex items-center justify-center">
          <span id="hero-progress-time" class="font-[var(--font-display)] text-[10px] tabular-nums text-[var(--color-ki-yellow)]">
            0:00
          </span>
        </div>
      </div>
      <span
        data-i18n="intro.time"
        class="pr-1 font-[var(--font-display)] text-[9px] uppercase tracking-wider opacity-90"
      >
        {dict.intro.time}
      </span>
    </div>

    <button
      type="button"
      id="hero-skip"
      class="btn-arcade pointer-events-auto"
      style="font-size: 0.7rem; padding: 0.45rem 0.9rem;"
    >
      <span aria-hidden="true">⤵</span>
      <span data-i18n="intro.skip">{dict.intro.skip}</span>
    </button>
  </div>
</section>

<style>
  @keyframes db-spin-kf {
    to { transform: rotate(360deg); }
  }
  .db-spin {
    animation: db-spin-kf 2.4s linear infinite;
  }
</style>

<script is:inline>
  (() => {
    const section = document.getElementById("hero-video");
    const video = document.getElementById("hero-video-el");
    const overlay = document.getElementById("hero-overlay");
    const bottomBar = document.getElementById("hero-bottom-bar");
    const loader = document.getElementById("hero-loader");
    const loaderTime = document.getElementById("loader-time");
    const loaderPercent = document.getElementById("loader-percent");
    const loaderProgress = document.getElementById("loader-progress");
    const progressRing = document.getElementById("hero-progress-ring");
    const progressTime = document.getElementById("hero-progress-time");
    const skip = document.getElementById("hero-skip");
    const mute = document.getElementById("hero-mute");
    const muteIcon = document.getElementById("hero-mute-icon");
    const muteLabel = document.getElementById("hero-mute-label");
    if (!section || !video) return;

    const RING_CIRCUMFERENCE = 2 * Math.PI * 15;
    const loadStart = performance.now();
    let loadEnd = null;
    let dismissed = false;

    const fmt = (ms) => (ms / 1000).toFixed(1) + "s";

    const tickTime = () => {
      if (loadEnd !== null || !loaderTime) return;
      loaderTime.textContent = fmt(performance.now() - loadStart);
      requestAnimationFrame(tickTime);
    };
    requestAnimationFrame(tickTime);

    const updateProgress = () => {
      try {
        if (video.duration > 0 && video.buffered.length > 0) {
          const end = video.buffered.end(video.buffered.length - 1);
          const pct = Math.min(100, Math.round((end / video.duration) * 100));
          if (loaderProgress) loaderProgress.style.width = pct + "%";
          if (loaderPercent) loaderPercent.textContent = pct + "%";
        }
      } catch {}
    };

    const updateVideoProgress = () => {
      if (!Number.isFinite(video.duration) || video.duration <= 0) return;
      const played = video.currentTime / video.duration;
      const remaining = Math.max(0, video.duration - video.currentTime);
      const m = Math.floor(remaining / 60);
      const s = Math.floor(remaining % 60);
      if (progressTime) {
        progressTime.textContent = `${m}:${String(s).padStart(2, "0")}`;
      }
      if (progressRing) {
        const offset = RING_CIRCUMFERENCE * (1 - played);
        progressRing.style.strokeDashoffset = String(offset);
      }
    };

    const revealVideo = () => {
      if (loadEnd !== null) return;
      loadEnd = performance.now();

      if (loaderTime) loaderTime.textContent = fmt(loadEnd - loadStart);
      if (loaderPercent) loaderPercent.textContent = "100%";
      if (loaderProgress) loaderProgress.style.width = "100%";

      video.style.opacity = "1";
      if (overlay) overlay.style.opacity = "1";
      if (bottomBar) bottomBar.style.opacity = "1";

      if (loader) {
        loader.style.opacity = "0";
        setTimeout(() => loader.remove(), 500);
      }

      updateVideoProgress();
    };

    video.addEventListener("progress", updateProgress);
    video.addEventListener("canplay", revealVideo);
    video.addEventListener("playing", revealVideo);
    video.addEventListener("timeupdate", updateVideoProgress);
    video.addEventListener("loadedmetadata", updateVideoProgress);

    video.addEventListener("error", () => {
      if (!loader) return;
      const errMsg = muteLabel?.getAttribute("data-i18n-error")
        || (location.pathname.startsWith("/en") ? "Could not load the video" : "No se pudo cargar el video");
      const contMsg = muteLabel?.getAttribute("data-i18n-continue")
        || (location.pathname.startsWith("/en") ? "Continue" : "Continuar");
      loader.innerHTML = `
        <div class="text-center px-6">
          <p class="text-4xl">⚠️</p>
          <p class="mt-3 font-[var(--font-display)] text-sm uppercase tracking-wider text-[var(--color-text)]">${errMsg}</p>
          <button id="loader-skip" class="btn-arcade mt-4 text-xs">${contMsg}</button>
        </div>
      `;
      const fallbackSkip = document.getElementById("loader-skip");
      if (fallbackSkip) fallbackSkip.addEventListener("click", dismiss);
    });

    const dismiss = () => {
      if (dismissed) return;
      dismissed = true;
      video.pause();
      video.style.opacity = "0";
      if (overlay) overlay.style.opacity = "0";
      if (bottomBar) bottomBar.style.opacity = "0";
      if (loader) loader.style.opacity = "0";

      document.body.classList.remove("overflow-hidden", "intro-mode");

      const below = document.getElementById("below-video");
      if (below) {
        setTimeout(() => {
          below.classList.remove("opacity-0", "pointer-events-none");
          below.removeAttribute("aria-hidden");
          below.removeAttribute("inert");
        }, 300);
      }

      setTimeout(() => {
        section.style.transition = "opacity 0.5s ease";
        section.style.opacity = "0";
        setTimeout(() => {
          section.style.display = "none";
        }, 500);
      }, 200);
    };

    video.addEventListener("ended", dismiss);
    if (skip) skip.addEventListener("click", dismiss);

    if (mute && muteIcon && muteLabel) {
      mute.addEventListener("click", () => {
        video.muted = !video.muted;
        const on = !video.muted;
        muteIcon.textContent = on ? "🔊" : "🔇";
        const dicts = {
          es: { mute: "Silenciar", unmute: "Activar sonido" },
          en: { mute: "Mute", unmute: "Unmute" },
        };
        const isEn = location.pathname.startsWith("/en");
        muteLabel.textContent = on ? dicts.en.unmute : dicts.en.mute;
        muteLabel.textContent = on
          ? (isEn ? dicts.en.unmute : dicts.es.unmute)
          : (isEn ? dicts.en.mute : dicts.es.mute);
        mute.setAttribute(
          "aria-label",
          on ? (isEn ? "Unmute" : "Activar sonido") : (isEn ? "Mute" : "Silenciar")
        );
      });
    }
  })();
</script>
