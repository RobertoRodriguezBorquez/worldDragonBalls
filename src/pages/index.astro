---
import Layout from "@layouts/Layout.astro";
import PresentacionVideo from "@components/PresentacionVideo.astro";
import Bienvenida from "@components/Bienvenida.astro";
import CharacterSelect from "@components/personajes/CharacterSelect.astro";
import VersusMode from "@components/VersusMode.astro";
import Sagas from "@components/Sagas.astro";
import { getFeaturedCharacters, parseKi, SAGAS } from "@lib/api";

const allCharacters = await getFeaturedCharacters();
const featured = allCharacters.slice(0, 16);
const raceCount = new Set(allCharacters.map((c) => c.race).filter(Boolean)).size;

const sortedByKi = [...featured].sort((a, b) => {
  const ka = parseKi(a.maxKi) || parseKi(a.ki);
  const kb = parseKi(b.maxKi) || parseKi(b.ki);
  return kb - ka;
});
const top1 = sortedByKi[0] ?? featured[0];
const top2 = sortedByKi[1] ?? featured[1] ?? featured[0];
---

<Layout
  title="World Dragon Balls | Inicio"
  description="Explora personajes, sagas y transformaciones del universo Dragon Ball."
  bodyClass="overflow-hidden intro-mode"
>
  <PresentacionVideo />

  <div
    id="below-video"
    class="pointer-events-none opacity-0 transition-opacity duration-700"
    aria-hidden="true"
    inert
  >
    <Bienvenida
      characterCount={allCharacters.length}
      sagaCount={SAGAS.length}
      raceCount={raceCount}
    />

    <section id="destacados" class="mx-auto max-w-7xl px-4">
      <CharacterSelect characters={featured} />
    </section>

    <VersusMode fighterA={top1} fighterB={top2} />

    <Sagas characters={allCharacters} />
  </div>
</Layout>
