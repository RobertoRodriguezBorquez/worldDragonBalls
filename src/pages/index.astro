---
import Layout from "@layouts/Layout.astro";
import PresentacionVideo from "@components/PresentacionVideo.astro";
import Bienvenida from "@components/Bienvenida.astro";
import CharacterCarousel from "@components/personajes/CharacterCarousel.astro";
import Categorias from "@components/Categorias.astro";
import SagasTimeline from "@components/timeline/SagasTimeline.astro";
import { getFeaturedCharacters } from "@lib/api";

const featured = (await getFeaturedCharacters()).slice(0, 12);
---

<Layout
  title="World Dragon Balls | Inicio"
  description="Explora personajes, sagas y transformaciones del universo Dragon Ball."
  bodyClass="overflow-hidden intro-mode"
>
  <PresentacionVideo />

  <div
    id="below-video"
    class="pointer-events-none opacity-0 transition-opacity duration-700"
    aria-hidden="true"
    inert
  >
    <Bienvenida />

    <section id="destacados" class="mx-auto max-w-7xl px-4 py-6">
      <div class="mb-4 flex items-baseline justify-between">
        <h2 class="text-lg font-bold text-[var(--color-text)] md:text-xl">
          Personajes destacados
        </h2>
        <a
          href="/personajes"
          class="text-sm font-semibold text-[var(--color-accent)] hover:underline"
        >
          Ver todos →
        </a>
      </div>
      <CharacterCarousel characters={featured} />
    </section>

    <Categorias />

    <SagasTimeline />
  </div>
</Layout>
